<!-- ══════════════════════════════════════
     JAVASCRIPT
══════════════════════════════════════ -->
<script>

// ─────────────────────────────────────
// DATA LAYER
// ─────────────────────────────────────
function getData(key, fallback) {
  try { return JSON.parse(localStorage.getItem(key)) || fallback; }
  catch { return fallback; }
}
function setData(key, val) {
  localStorage.setItem(key, JSON.stringify(val));
}

function getUsers() { return getData('mbp_users', []); }
function setUsers(u) { setData('mbp_users', u); }
function getPanels() { return getData('mbp_panels', []); }
function setPanels(p) { setData('mbp_panels', p); }
function getCurrentUser() {
  const id = localStorage.getItem('mbp_currentUser');
  if (!id) return null;
  return getUsers().find(u => u.id === id) || null;
}
function setCurrentUser(id) { localStorage.setItem('mbp_currentUser', id || ''); }

function uid() { return Date.now().toString(36) + Math.random().toString(36).substr(2, 5); }
function fmtDate(iso) {
  const d = new Date(iso);
  return d.toLocaleDateString('en-US', {year:'numeric',month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'});
}

// ─────────────────────────────────────
// PAGE ROUTING
// ─────────────────────────────────────
let currentPage = 'landing';

function showPage(name) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  const el = document.getElementById('page-' + name);
  if (el) { el.classList.add('active'); currentPage = name; }
  window.scrollTo(0, 0);
  onPageLoad(name);
  updateNavArrows();
}

function onPageLoad(name) {
  const user = getCurrentUser();
  // Nav
  document.getElementById('nav-login').style.display = user ? 'none' : '';
  document.getElementById('nav-signup').style.display = user ? 'none' : '';
  document.getElementById('nav-dashboard').style.display = user ? '' : 'none';
  document.getElementById('nav-logout').style.display = user ? '' : 'none';

  if (name === 'dashboard' && user) {
    document.getElementById('dash-greeting').textContent = 'Welcome, ' + user.name.split(' ')[0] + '!';
    renderRecentPanels();
  }
  if (name === 'your-panels') renderPanelsList();
  if (name === 'edit-user' && user) {
    document.getElementById('eu-name').value = user.name;
    document.getElementById('eu-email').value = user.email;
    document.getElementById('eu-password').value = '';
    document.getElementById('edituser-success').style.display = 'none';
  }
  if (name === 'add-panel' && user) {
    document.getElementById('ap-cname').value = user.name || '';
    document.getElementById('ap-cemail').value = user.email || '';
  }
}

// Check URL params on load (for QR code links)
window.addEventListener('DOMContentLoaded', () => {
  const params = new URLSearchParams(window.location.search);
  const pid = params.get('panel');
  if (pid) {
    openPanelById(pid, false);
  } else {
    showPage('landing');
  }
});

// ─────────────────────────────────────
// AUTH
// ─────────────────────────────────────
function doSignUp() {
  const name = document.getElementById('signup-name').value.trim();
  const username = document.getElementById('signup-username').value.trim();
  const password = document.getElementById('signup-password').value;
  const email = document.getElementById('signup-email').value.trim();
  const err = document.getElementById('signup-error');
  err.style.display = 'none';

  if (!name || !username || !password || !email) { err.textContent = 'All fields are required.'; err.style.display = 'block'; return; }
  if (password.length < 6) { err.textContent = 'Password must be at least 6 characters.'; err.style.display = 'block'; return; }

  const users = getUsers();
  if (users.find(u => u.username.toLowerCase() === username.toLowerCase())) {
    err.textContent = 'That username is already taken.'; err.style.display = 'block'; return;
  }
  const newUser = { id: uid(), name, username, password, email, createdDate: new Date().toISOString() };
  users.push(newUser);
  setUsers(users);
  setCurrentUser(newUser.id);
  showPage('dashboard');
}

function doLogin() {
  const username = document.getElementById('login-username').value.trim();
  const password = document.getElementById('login-password').value;
  const err = document.getElementById('login-error');
  err.style.display = 'none';
  const user = getUsers().find(u => u.username.toLowerCase() === username.toLowerCase() && u.password === password);
  if (!user) { err.textContent = 'Invalid username or password.'; err.style.display = 'block'; return; }
  setCurrentUser(user.id);
  showPage('dashboard');
}

function logOut() {
  setCurrentUser(null);
  showPage('landing');
}

function saveUserEdits() {
  const user = getCurrentUser();
  if (!user) return;
  const name = document.getElementById('eu-name').value.trim();
  const email = document.getElementById('eu-email').value.trim();
  const pw = document.getElementById('eu-password').value;
  const users = getUsers();
  const idx = users.findIndex(u => u.id === user.id);
  if (idx === -1) return;
  if (name) users[idx].name = name;
  if (email) users[idx].email = email;
  if (pw && pw.length >= 6) users[idx].password = pw;
  setUsers(users);
  document.getElementById('edituser-success').textContent = 'Profile updated successfully!';
  document.getElementById('edituser-success').style.display = 'block';
}

// ─────────────────────────────────────
// ADD NEW PANEL
// ─────────────────────────────────────
let currentPanelId = null; // the panel being worked on

function saveNewPanel() {
  const address = document.getElementById('ap-address').value.trim();
  const panelId = document.getElementById('ap-panelid').value.trim().toUpperCase();
  const manufacturer = document.getElementById('ap-manufacturer').value.trim();
  const location = document.getElementById('ap-location').value.trim();
  const numBreakers = parseInt(document.getElementById('ap-numbreakers').value);
  const cname = document.getElementById('ap-cname').value.trim();
  const cphone = document.getElementById('ap-cphone').value.trim();
  const cemail = document.getElementById('ap-cemail').value.trim();
  const err = document.getElementById('addpanel-error');
  err.style.display = 'none';

  if (!address || !panelId || !numBreakers) {
    err.textContent = 'Street address, Panel ID, and number of breakers are required.';
    err.style.display = 'block'; return;
  }
  const panels = getPanels();
  if (panels.find(p => p.panelId === panelId)) {
    err.textContent = 'Panel ID "' + panelId + '" already exists. Choose a unique ID.';
    err.style.display = 'block'; return;
  }

  const user = getCurrentUser();
  const breakers = [];
  for (let i = 1; i <= numBreakers; i++) {
    breakers.push({ number: i, description: '', history: [] });
  }

  const panel = {
    id: uid(),
    panelId,
    streetAddress: address,
    locationDescription: location,
    manufacturer,
    numBreakers,
    breakers,
    createdDate: new Date().toISOString(),
    createdBy: { name: cname, phone: cphone, email: cemail },
    ownerId: user ? user.id : null,
    qrCodeGenerated: false
  };
  panels.push(panel);
  setPanels(panels);
  currentPanelId = panel.id;

  // Clear form
  ['ap-address','ap-panelid','ap-manufacturer','ap-location','ap-cname','ap-cphone','ap-cemail'].forEach(id => {
    document.getElementById(id).value = '';
  });
  document.getElementById('ap-numbreakers').value = '';

  openPanelSetup(panel.id);
}

function openPanelSetup(panelInternalId) {
  const panel = getPanels().find(p => p.id === panelInternalId);
  if (!panel) return;
  currentPanelId = panelInternalId;
  document.getElementById('setup-title').textContent = 'Label Breakers — ' + panel.panelId;
  renderSetupGrid(panel);
  showPage('panel-setup');
}

function renderSetupGrid(panel) {
  const grid = document.getElementById('setup-breakers-grid');
  grid.innerHTML = '';
  panel.breakers.forEach(br => {
    const slot = document.createElement('div');
    slot.className = 'breaker-slot-edit';
    slot.id = 'setup-slot-' + br.number;
    slot.innerHTML = `
      <div class="breaker-num-edit">${br.number}</div>
      <div style="flex:1">
        <textarea class="breaker-input" id="setup-br-${br.number}" rows="2"
          placeholder="Click to describe this breaker…">${br.description}</textarea>
      </div>`;
    grid.appendChild(slot);
  });
}

function confirmPanelSetup() {
  // Save whatever is in the inputs
  const panels = getPanels();
  const idx = panels.findIndex(p => p.id === currentPanelId);
  if (idx === -1) return;
  panels[idx].breakers.forEach(br => {
    const input = document.getElementById('setup-br-' + br.number);
    if (input) br.description = input.value.trim();
  });
  panels[idx].qrCodeGenerated = true;
  setPanels(panels);
  showQRPage(panels[idx]);
}

// ─────────────────────────────────────
// QR CODE
// ─────────────────────────────────────
function showQRPage(panel) {
  document.getElementById('qr-panel-name').textContent = panel.panelId + ' — ' + panel.streetAddress;
  document.getElementById('qr-panel-id-text').textContent = panel.panelId;

  // QR code links to the site; user enters the Panel ID shown on the printout
  const url = window.location.href.split('?')[0];

  const container = document.getElementById('qr-code-display');
  container.innerHTML = '';
  new QRCode(container, {
    text: url,
    width: 200,
    height: 200,
    colorDark: '#1e3a8a',
    colorLight: '#ffffff',
    correctLevel: QRCode.CorrectLevel.H
  });

  currentPanelId = panel.id;
  showPage('qr');
}

function goToPanelView() {
  openPanelById_Internal(currentPanelId, true);
}

function showQRForCurrentPanel() {
  const panel = getPanels().find(p => p.id === currentPanelId);
  if (panel) showQRPage(panel);
}

// ─────────────────────────────────────
// YOUR PANELS
// ─────────────────────────────────────
function renderRecentPanels() {
  const user = getCurrentUser();
  const panels = getPanels().filter(p => p.ownerId === (user ? user.id : null));
  const el = document.getElementById('dash-recent-panels');
  if (panels.length === 0) {
    el.innerHTML = '<p style="color:#9ca3af;font-size:0.92rem;">No panels yet. <a href="#" onclick="showPage(\'add-panel\')">Add your first panel →</a></p>';
    return;
  }
  el.innerHTML = panels.slice(-3).reverse().map(p => panelItemHTML(p)).join('');
}

function renderPanelsList() {
  const user = getCurrentUser();
  const search = (document.getElementById('panels-search')?.value || '').toLowerCase();
  let panels = getPanels().filter(p => p.ownerId === (user ? user.id : null));

  if (search) {
    panels = panels.filter(p =>
      p.panelId.toLowerCase().includes(search) ||
      p.streetAddress.toLowerCase().includes(search) ||
      p.breakers.some(b => b.description.toLowerCase().includes(search))
    );
  }
  const el = document.getElementById('panels-list');
  if (panels.length === 0) {
    el.innerHTML = '<p style="color:#9ca3af;font-size:0.92rem;">' + (search ? 'No panels match your search.' : 'No panels yet. <a href="#" onclick="showPage(\'add-panel\')">Add your first panel →</a>') + '</p>';
    return;
  }
  el.innerHTML = panels.map(p => panelItemHTML(p)).join('');
}

function panelItemHTML(p) {
  return `
    <div class="panel-item">
      <div class="panel-item-info">
        <h3>${p.panelId} <span class="badge badge-blue">${p.numBreakers} breakers</span> ${p.qrCodeGenerated ? '<span class="badge badge-green">QR ✓</span>' : ''}</h3>
        <p>${p.streetAddress}${p.locationDescription ? ' · ' + p.locationDescription : ''}</p>
        <p style="margin-top:2px;font-size:0.8rem;color:#9ca3af">Added ${fmtDate(p.createdDate)}</p>
      </div>
      <div class="panel-item-actions">
        <button class="btn btn-sm btn-blue" onclick="openPanelById_Internal('${p.id}', true)">View/Edit</button>
        <button class="btn btn-sm btn-outline" onclick="openSetupQR('${p.id}')">QR Code</button>
        <button class="btn btn-sm btn-outline" onclick="openPanelHistory('${p.id}')">History</button>
        <button class="btn btn-sm btn-danger" onclick="deletePanel('${p.id}')">Delete</button>
      </div>
    </div>`;
}

function filterPanelsList() { renderPanelsList(); }

function openSetupQR(internalId) {
  const panel = getPanels().find(p => p.id === internalId);
  if (panel) showQRPage(panel);
}

function deletePanel(internalId) {
  if (!confirm('Delete this panel? This cannot be undone.')) return;
  const panels = getPanels().filter(p => p.id !== internalId);
  setPanels(panels);
  renderPanelsList();
  renderRecentPanels();
}

// ─────────────────────────────────────
// VIEW / EDIT PANEL
// ─────────────────────────────────────
function openPanelById(panelId, showBackBtn) {
  // lookup by panelId string
  const panel = getPanels().find(p => p.panelId === panelId.toUpperCase());
  if (!panel) {
    const err = document.getElementById('landing-panel-error');
    if (err) { err.style.display = 'block'; }
    showPage('landing');
    return;
  }
  currentPanelId = panel.id;
  openPanelById_Internal(panel.id, showBackBtn);
}

function lookupPanelId() {
  const val = document.getElementById('landing-panel-id').value.trim();
  if (!val) return;
  const err = document.getElementById('landing-panel-error');
  err.style.display = 'none';
  const panel = getPanels().find(p => p.panelId === val.toUpperCase());
  if (!panel) { err.style.display = 'block'; return; }
  currentPanelId = panel.id;
  openPanelById_Internal(panel.id, false);
}

function openPanelById_Internal(internalId, showBackBtn) {
  const panel = getPanels().find(p => p.id === internalId);
  if (!panel) return;
  currentPanelId = internalId;

  document.getElementById('vp-title').textContent = 'Panel: ' + panel.panelId;
  document.getElementById('vp-subtitle').textContent = panel.streetAddress + (panel.locationDescription ? ' · ' + panel.locationDescription : '');
  document.getElementById('vp-manufacturer').textContent = panel.manufacturer ? '🏭 ' + panel.manufacturer : '';
  document.getElementById('vp-back-btn').style.display = showBackBtn ? '' : 'none';

  // Show Edit Info button only for logged-in owner
  const editInfoBtn = document.getElementById('vp-edit-info-btn');
  if (editInfoBtn) {
    const user = getCurrentUser();
    editInfoBtn.style.display = (user && (!panel.ownerId || panel.ownerId === user.id)) ? '' : 'none';
  }

  // Print header
  document.getElementById('print-panel-title').textContent = 'Panel ID: ' + panel.panelId + ' — ' + panel.streetAddress;
  document.getElementById('print-panel-meta').textContent = (panel.manufacturer ? 'Manufacturer: ' + panel.manufacturer + '  ·  ' : '') + panel.numBreakers + ' breakers';
  document.getElementById('print-date').textContent = 'Printed: ' + fmtDate(new Date().toISOString());

  renderEditGrid(panel);
  showPage('view-panel');
}

function renderEditGrid(panel) {
  const grid = document.getElementById('vp-breakers-grid');
  grid.innerHTML = '';
  panel.breakers.forEach(br => {
    const slot = document.createElement('div');
    slot.className = 'breaker-slot-edit';
    slot.id = 'vp-slot-' + br.number;
    slot.innerHTML = `
      <div class="breaker-num-edit">${br.number}</div>
      <div style="flex:1">
        <textarea class="breaker-input" id="vp-br-${br.number}" rows="2"
          placeholder="Click to describe breaker ${br.number}…">${br.description}</textarea>
      </div>`;
    grid.appendChild(slot);
  });
}

function searchBreakers() {
  const q = document.getElementById('vp-search').value.toLowerCase();
  const panel = getPanels().find(p => p.id === currentPanelId);
  if (!panel) return;
  panel.breakers.forEach(br => {
    const slot = document.getElementById('vp-slot-' + br.number);
    if (!slot) return;
    if (!q) { slot.style.opacity = '1'; return; }
    const match = br.description.toLowerCase().includes(q);
    slot.style.opacity = match ? '1' : '0.3';
    slot.style.borderColor = match ? '#1a56db' : '#e5e7eb';
  });
}

// ─────────────────────────────────────
// SAVE BREAKERS (with contact info modal)
// ─────────────────────────────────────
function saveAllBreakers() {
  const user = getCurrentUser();
  if (user) {
    // Pre-fill from user data
    document.getElementById('sm-name').value = user.name || '';
    document.getElementById('sm-email').value = user.email || '';
  }
  document.getElementById('save-modal-error').style.display = 'none';
  document.getElementById('save-modal').style.display = 'flex';
}

function closeSaveModal() {
  document.getElementById('save-modal').style.display = 'none';
}

function confirmSaveBreakers() {
  const name = document.getElementById('sm-name').value.trim();
  const phone = document.getElementById('sm-phone').value.trim();
  const email = document.getElementById('sm-email').value.trim();
  const address = document.getElementById('sm-address').value.trim();
  const err = document.getElementById('save-modal-error');
  if (!name || !phone || !email) {
    err.textContent = 'Name, phone, and email are required.';
    err.style.display = 'block'; return;
  }

  const panels = getPanels();
  const idx = panels.findIndex(p => p.id === currentPanelId);
  if (idx === -1) return;

  const now = new Date().toISOString();
  panels[idx].breakers.forEach(br => {
    const input = document.getElementById('vp-br-' + br.number);
    if (!input) return;
    const newDesc = input.value.trim();
    if (newDesc !== br.description) {
      br.history.push({
        date: now,
        previousDescription: br.description,
        newDescription: newDesc,
        contactName: name,
        contactPhone: phone,
        contactEmail: email,
        contactAddress: address
      });
      br.description = newDesc;
    }
  });
  setPanels(panels);
  closeSaveModal();

  // Flash success
  const btn = document.querySelector('#page-view-panel .btn-blue');
  if (btn) { btn.textContent = '✅ Saved!'; setTimeout(() => { btn.textContent = '💾 Save All Changes'; }, 2000); }
}

// ─────────────────────────────────────
// HISTORY
// ─────────────────────────────────────
function openPanelHistory(internalId) {
  const panel = getPanels().find(p => p.id === internalId);
  if (!panel) return;
  currentPanelId = internalId;
  document.getElementById('hist-title').textContent = 'History: ' + panel.panelId;
  renderHistory(panel);
  showPage('history');
}

function viewBreakerHistory() {
  openPanelHistory(currentPanelId);
}

function renderHistory(panel) {
  const el = document.getElementById('history-list');
  // Gather all history events across breakers
  const events = [];
  panel.breakers.forEach(br => {
    br.history.forEach(h => events.push({ ...h, breakerNumber: br.number }));
  });
  events.sort((a, b) => new Date(b.date) - new Date(a.date));

  if (events.length === 0) {
    el.innerHTML = '<p style="color:#9ca3af;">No changes recorded yet.</p>';
    return;
  }
  el.innerHTML = events.map(h => `
    <div class="history-item">
      <div class="hist-date">${fmtDate(h.date)}</div>
      <div class="hist-breaker">Breaker #${h.breakerNumber}</div>
      <div class="hist-desc">
        ${h.previousDescription ? `<span style="color:#9ca3af;text-decoration:line-through">${h.previousDescription}</span> → ` : ''}
        <strong>${h.newDescription || '<em>cleared</em>'}</strong>
      </div>
      <div class="hist-contact">By: ${h.contactName} · ${h.contactPhone} · ${h.contactEmail}${h.contactAddress ? ' · ' + h.contactAddress : ''}</div>
    </div>`).join('');
}

