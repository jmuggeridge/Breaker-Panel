// ─────────────────────────────────────
// EDIT PANEL INFO
// ─────────────────────────────────────
function openEditPanelInfoModal() {
  const user = getCurrentUser();
  if (!user) { alert('You must be logged in to edit panel information.'); return; }
  const panel = getPanels().find(p => p.id === currentPanelId);
  if (!panel) return;
  if (panel.ownerId && panel.ownerId !== user.id) {
    alert('You can only edit panels that belong to your account.');
    return;
  }
  document.getElementById('epi-address').value = panel.streetAddress || '';
  document.getElementById('epi-manufacturer').value = panel.manufacturer || '';
  document.getElementById('epi-location').value = panel.locationDescription || '';
  document.getElementById('epi-numbreakers').value = panel.numBreakers || '';
  document.getElementById('epi-error').style.display = 'none';
  document.getElementById('edit-panel-info-modal').style.display = 'flex';
}

function closeEditPanelInfoModal() {
  document.getElementById('edit-panel-info-modal').style.display = 'none';
}

function saveEditPanelInfo() {
  const user = getCurrentUser();
  if (!user) { alert('You must be logged in to edit panel information.'); return; }

  const address = document.getElementById('epi-address').value.trim();
  const manufacturer = document.getElementById('epi-manufacturer').value;
  const location = document.getElementById('epi-location').value.trim();
  const newNumBreakers = parseInt(document.getElementById('epi-numbreakers').value);
  const err = document.getElementById('epi-error');

  if (!address) {
    err.textContent = 'Street address is required.';
    err.style.display = 'block'; return;
  }
  if (!newNumBreakers || newNumBreakers < 1 || newNumBreakers > 200) {
    err.textContent = 'Number of breakers must be between 1 and 200.';
    err.style.display = 'block'; return;
  }

  const panels = getPanels();
  const idx = panels.findIndex(p => p.id === currentPanelId);
  if (idx === -1) return;
  if (panels[idx].ownerId && panels[idx].ownerId !== user.id) {
    err.textContent = 'You can only edit panels that belong to your account.';
    err.style.display = 'block'; return;
  }

  // Handle breaker count changes
  const oldNum = panels[idx].numBreakers;
  if (newNumBreakers < oldNum) {
    const removedWithDesc = panels[idx].breakers
      .filter(b => b.number > newNumBreakers && b.description).length;
    if (removedWithDesc > 0) {
      if (!confirm(`Reducing from ${oldNum} to ${newNumBreakers} breakers will permanently delete ${removedWithDesc} breaker(s) that have descriptions. Continue?`)) return;
    }
    panels[idx].breakers = panels[idx].breakers.filter(b => b.number <= newNumBreakers);
  } else if (newNumBreakers > oldNum) {
    for (let i = oldNum + 1; i <= newNumBreakers; i++) {
      panels[idx].breakers.push({ number: i, description: '', history: [] });
    }
  }
  panels[idx].numBreakers = newNumBreakers;

  panels[idx].streetAddress = address;
  panels[idx].manufacturer = manufacturer;
  panels[idx].locationDescription = location;
  setPanels(panels);

  // Refresh the page header live
  document.getElementById('vp-subtitle').textContent = address + (location ? ' · ' + location : '');
  document.getElementById('vp-manufacturer').textContent = manufacturer ? '🏭 ' + manufacturer : '';

  // Update print header too
  document.getElementById('print-panel-title').textContent = 'Panel ID: ' + panels[idx].panelId + ' — ' + address;
  document.getElementById('print-panel-meta').textContent = (manufacturer ? 'Manufacturer: ' + manufacturer + '  ·  ' : '') + newNumBreakers + ' breakers';

  // Re-render breaker grid if count changed
  if (newNumBreakers !== oldNum) renderEditGrid(panels[idx]);

  closeEditPanelInfoModal();

  // Flash confirmation on button
  const btn = document.getElementById('vp-edit-info-btn');
  if (btn) { btn.textContent = '✅ Saved!'; setTimeout(() => { btn.textContent = '✏️ Edit Info'; }, 2000); }
}

// ─────────────────────────────────────
// PAGE NAVIGATION ARROWS
// ─────────────────────────────────────
const PAGE_ORDER = [
  'landing', 'about', 'contact',
  'login', 'signup',
  'dashboard', 'your-panels', 'add-panel', 'panel-setup', 'qr', 'view-panel', 'history', 'edit-user'
];

function updateNavArrows() {
  const idx = PAGE_ORDER.indexOf(currentPage);
  const prevBtn = document.getElementById('nav-prev-btn');
  const nextBtn = document.getElementById('nav-next-btn');
  if (prevBtn) prevBtn.disabled = idx <= 0;
  if (nextBtn) nextBtn.disabled = idx >= PAGE_ORDER.length - 1;
}

function navigatePrev() {
  const idx = PAGE_ORDER.indexOf(currentPage);
  if (idx > 0) showPage(PAGE_ORDER[idx - 1]);
}

function navigateNext() {
  const idx = PAGE_ORDER.indexOf(currentPage);
  if (idx < PAGE_ORDER.length - 1) showPage(PAGE_ORDER[idx + 1]);
}

// ─────────────────────────────────────
// PRINT: show/hide print-only elements
// ─────────────────────────────────────
window.addEventListener('beforeprint', () => {
  document.getElementById('print-header').style.display = 'block';
  document.getElementById('page-view-panel').classList.add('print-target');
  document.querySelectorAll('.page').forEach(p => { if (!p.id.includes('view-panel')) p.classList.add('no-print'); });
});
window.addEventListener('afterprint', () => {
  document.getElementById('print-header').style.display = 'none';
  document.getElementById('page-view-panel').classList.remove('print-target');
  document.querySelectorAll('.page').forEach(p => p.classList.remove('no-print'));
});

